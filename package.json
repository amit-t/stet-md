{
  "name": "redline-md",
  "version": "0.1.0",
  "description": "Local Markdown review utility: threaded review comments that live inside Markdown files with byte-splice persistence, agent CLI, and browser UI.",
  "keywords": [
    "markdown",
    "review",
    "comments",
    "annotations",
    "local-first",
    "cli",
    "agents"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "bin": {
    "redline": "dist/cli/main.js",
    "rl": "dist/cli/main.js",
    "redline-md": "dist/cli/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./safety": {
      "types": "./dist/safety/index.d.ts",
      "import": "./dist/safety/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist/",
    "docs/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests/core tests/cli tests/safety tests/server tests/security tests/browser",
    "test:core": "vitest run tests/core",
    "test:cli": "vitest run tests/cli",
    "test:server": "vitest run tests/server tests/security",
    "test:browser": "vitest run tests/browser",
    "test:packaging": "pnpm run build && vitest run tests/packaging",
    "ci": "pnpm run typecheck && pnpm test && pnpm run test:packaging",
    "pack:dry": "pnpm pack --dry-run",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run ci"
  },
  "dependencies": {
    "js-yaml": "^4.2.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "happy-dom": "latest",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/amittiwari/redline.git"
  },
  "homepage": "https://github.com/amittiwari/redline#readme",
  "bugs": {
    "url": "https://github.com/amittiwari/redline/issues"
  },
  "packageManager": "pnpm@10.33.0"
}
